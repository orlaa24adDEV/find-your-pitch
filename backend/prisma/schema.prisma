generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  age       Int?
  email     String    @unique
  password  String
  role      String    @default("user")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Field {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  location    String
  sport       String
  priceHour   Float
  imageUrl    String?
  lat         Float?
  lng         Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
}

model Booking {
  id        Int      @id @default(autoincrement())
  date      DateTime
  startTime String
  endTime   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  fieldId   Int
  user      User     @relation(fields: [userId], references: [id])
  field     Field    @relation(fields: [fieldId], references: [id])

  //EVITAR DOBLE RESERVA
  @@unique([fieldId, date, startTime])
}
